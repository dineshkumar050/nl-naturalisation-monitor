{
  "name": "nl-naturalisation-monitor",
  "version": "1.0.0",
  "description": "Agentic AI monitor for Netherlands naturalisation language level changes (A2 → B1)",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node api/server.js",
    "client": "react-scripts start",
    "build": "react-scripts build",
    "start": "node api/server.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  },
  "proxy": "http://localhost:3001"
}
